def portfolio_opt(stocks_names: numpy.typing.ArrayLike, num_stocks_to_buy: int, budget: float, returns_in: numpy.typing.ArrayLike, 
                  price_in: numpy.typing.ArrayLike, covariance_in: numpy.typing.ArrayLike, coskewness_in: numpy.typing.ArrayLike) -> Model:
 
    # Construct the model
    model = Model()
    returns_arr = np.array(returns_in, dtype ='float32')
    price_arr = np.array(price_in, dtype ='float32')
    covariance_arr = np.array(covariance_in, dtype ='float32')
    

    # Convert inputs to model constants
    returns = model.constant(returns_arr)
    price = model.constant(price_arr)
    covariance = model.constant(covariance_arr)
    
    # Make coskewness array a constant of the model
    if coskewness_in is not None:
      coskewness_arr = np.array(coskewness_in, dtype = 'float32')
      coskewness = model.constant(coskewness_arr)
      
    budget = model.constant(budget)
    num_stocks_to_buy = model.constant(num_stocks_to_buy)

    # Define decision variables
    stocks = model.binary(len(stocks_names))
    #set minimum and maximum number of shares that can be assigned to each stock
    shares = model.integer(len(stocks_names), lower_bound = 0, upper_bound=10000) 

    # Add model constraints
     #Full allocation constraint
    _= model.add_constraint(sum(price[i] * shares[i]  for i in range(len(stocks_names))) >= budget*0.90)

    #BudgetConstraint
    _= model.add_constraint(sum(price[i] * shares[i]  for i in range(len(stocks_names))) <= budget)
    
    # add coskew constraint, don't add if the stocks list is too large
    if len(stocks_names) <= 100:
      coskewness_matrix = (
      price_arr[:, None, None] * 
      price_arr[None, :, None] * 
      price_arr[None, None, :] * 
      coskewness_arr
      ) / budget

      n=len(stocks_names)
      indices = np.array(list(combinations_with_replacement(range(n), 3)))
      i, j, k = indices[:, 0], indices[:, 1], indices[:, 2]
      risk_weights_3rd = coskewness_matrix[i, j, k]
      skew_constraint = (risk_weights_3rd * (shares[i] * shares[j] * shares[k])).sum()
      _=model.add_constraint(skew_constraint >= -0.15)

    # Cardinality constraint - choose exactly k stocks
    _= model.add_constraint(sum(stocks[i] for i in range(len(stocks_names))) == num_stocks_to_buy)

    # Constrain the number of shares to less than 1000 if a stock is selected, and to at least 1 if a stock is selected
    for i in range(len(stocks_names)):
      # Upper Bound: shares[i] must be 0 if stocks[i] is 0
      model.add_constraint(shares[i] <= 10000 * stocks[i])
      # Lower Bound: shares[i] must be at least 1 if stocks[i] is 1
      model.add_constraint(shares[i] >= 1 * stocks[i])

    # Define components of the objective function
    # Return component - minimize the negative to maximize
    return_obj = sum(r * s1  for r, s1 in zip(returns, shares))

    # Risk component - use variance and covariance to approximate risk
    risk_matrix = (price_arr[:, None] * covariance_arr * price_arr)/budget
    i, j = np.triu_indices(len(stocks_names), k=0)
    risk_weights = risk_matrix[i, j] 
    risk_obj = (risk_weights * (shares[i] * shares[j])).sum()

    #combine return and risk terms
    #alpha scales the importance of the risk, beta scales the importance of the return
    alpha = 0.1
    beta  = 1 - alpha
 
    model.minimize(beta * risk_obj - alpha*return_obj)

    # finalize model
    model.lock()
    return model

